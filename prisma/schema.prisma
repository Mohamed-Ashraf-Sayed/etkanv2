generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Booking {
  id          String   @id @default(cuid())
  type        String   // consultation | quote
  status      String   @default("pending") // pending | confirmed | cancelled | completed
  name        String
  email       String
  phone       String
  date        String?
  timeSlot    String?
  serviceType String?
  notes       String?  @db.Text
  services    String?  @db.Text
  features    String?  @db.Text
  budget      String?
  timeline    String?
  company     String?
  description String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model ChatSession {
  id           String   @id @default(cuid())
  sessionId    String   @unique
  clientNumber Int
  isAdminMode  Boolean  @default(false)
  messages     String   @default("[]") @db.LongText
  lastActivity DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?  @db.Text
  ip        String?
  country   String?
  city      String?
  sessionId String
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path])
  @@index([sessionId])
  @@index([ip])
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  category    String   // website | mobile | systems | infrastructure
  title       String
  titleEn     String   @default("")
  client      String
  clientEn    String   @default("")
  industry    String
  industryEn  String   @default("")
  summary     String   @db.Text
  summaryEn   String   @default("") @db.Text
  description String   @db.Text
  descriptionEn String @default("") @db.Text
  problem     String   @db.Text
  problemEn   String   @default("") @db.Text
  solution    String   @db.Text
  solutionEn  String   @default("") @db.Text
  results     String   @default("[]") @db.Text
  resultsEn   String   @default("[]") @db.Text
  tags        String   @default("[]") @db.Text
  tagsEn      String   @default("[]") @db.Text
  testimonial String   @default("{}") @db.Text
  testimonialEn String @default("{}") @db.Text
  techStack   String   @default("[]") @db.Text
  thumbnail   String   @default("")
  images      String   @default("[]") @db.Text
  duration    String   @default("")
  durationEn  String   @default("")
  year        String   @default("")
  displayOrder Int     @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
